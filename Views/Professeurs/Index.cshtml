@model IEnumerable<Professeur>
@{
    ViewData["Title"] = "Professeurs";
}

<section class="page-header page-header-inline">
    <div><h1>Professeurs</h1></div>
    <a asp-action="Create" class="btn btn-primary">Nouveau professeur</a>
</section>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Spécialité</th>
                    <th>Grade</th>
                    <th>Référentiel</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NomComplet</td>
                        <td>@item.Email</td>
                        <td>@item.Specialite</td>
                        <td>@item.Grade</td>
                        <td>@item.ReferentielPrincipal?.Libelle</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Modifier</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
