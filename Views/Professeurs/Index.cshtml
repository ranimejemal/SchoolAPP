@model IEnumerable<Professeur>
@{
    ViewData["Title"] = "Professeurs";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Administration</span>
        <h1>Gestion des professeurs</h1>
        <p class="page-subtitle">Organisation des enseignants, specialites, grades et referentiels principaux.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nouveau professeur</a>
</section>

<div class="panel-card">
    <div class="table-card__header">
        <div>
            <h2>Liste des professeurs</h2>
            <p class="muted-copy mb-0">@Model.Count() professeur(s) disponibles.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Professeur</th>
                    <th>Specialite</th>
                    <th>Grade</th>
                    <th>Referentiel</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="entity-main">@item.NomComplet</span>
                            <span class="entity-sub">@item.Email</span>
                        </td>
                        <td>@item.Specialite</td>
                        <td><span class="pill pill--neutral">@item.Grade</span></td>
                        <td>@(item.ReferentielPrincipal?.Libelle ?? "Non defini")</td>
                        <td>
                            <div class="action-row">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Modifier</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
