@model IEnumerable<Compte>
@{
    ViewData["Title"] = "Comptes";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Administration</span>
        <h1>Gestion des comptes</h1>
        <p class="page-subtitle">Creation, edition et suppression des acces utilisateurs.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nouveau compte</a>
</section>

<div class="panel-card">
    <div class="table-card__header">
        <div>
            <h2>Liste des comptes</h2>
            <p class="muted-copy mb-0">@Model.Count() compte(s) disponibles.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Login</th>
                    <th>Nom affiche</th>
                    <th>Role</th>
                    <th>Etudiant lie</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="entity-main">@item.Email</span>
                        </td>
                        <td>@item.DisplayName</td>
                        <td><span class="pill pill--neutral">@item.Role</span></td>
                        <td>@(item.Etudiant?.NomComplet ?? "Aucun")</td>
                        <td>
                            <div class="action-row">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Modifier</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
