<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolApp.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="site-header">
            <nav class="navbar navbar-expand-lg navbar-dark">
                <div class="container">
                    <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">SchoolApp</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                            </li>
                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Comptes" asp-action="Index">Comptes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Etudiants" asp-action="Index">Etudiants</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Professeurs" asp-action="Index">Professeurs</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Referentiels" asp-action="Index">Referentiels</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Absences" asp-action="Index">Absences</a></li>
                            }
                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("User"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="StudentPortal" asp-action="MyAbsences">Mes absences</a></li>
                            }
                        </ul>
                        <div class="d-flex align-items-center gap-2">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="user-badge">@User.Identity.Name</span>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-light">Déconnexion</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-light" asp-controller="Auth" asp-action="Login">Connexion</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="container page-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
