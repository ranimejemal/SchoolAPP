<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolApp.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="site-header">
            <div class="container">
                <nav class="navbar navbar-expand-lg">
                    <a class="brand-mark" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark__badge">SA</span>
                        <span>
                            <strong>SchoolApp</strong>
                            <small>Administration academique</small>
                        </span>
                    </a>

                    <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                            </li>
                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Comptes" asp-action="Index">Comptes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Etudiants" asp-action="Index">Etudiants</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Professeurs" asp-action="Index">Professeurs</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Referentiels" asp-action="Index">Referentiels</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Absences" asp-action="Index">Absences</a></li>
                            }
                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("User"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="StudentPortal" asp-action="MyAbsences">Mes absences</a></li>
                            }
                        </ul>

                        <div class="header-actions">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <div class="identity-chip">
                                    <span class="identity-chip__label">Connecte</span>
                                    <strong>@User.Identity.Name</strong>
                                </div>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-soft">Deconnexion</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-soft" asp-controller="Auth" asp-action="Login">Connexion</a>
                            }
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <main class="container app-main">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="container site-footer__content">
                <span>SchoolApp</span>
                <span>Gestion des comptes, absences et referentiels.</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
