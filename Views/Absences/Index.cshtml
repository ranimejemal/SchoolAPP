@model IEnumerable<Absence>
@{
    ViewData["Title"] = "Absences";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Administration</span>
        <h1>Gestion des absences</h1>
        <p class="page-subtitle">Suivi des dates, motifs, durees et etats de justification.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nouvelle absence</a>
</section>

<div class="panel-card">
    <div class="table-card__header">
        <div>
            <h2>Historique des absences</h2>
            <p class="muted-copy mb-0">@Model.Count() absence(s) referencees.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Etudiant</th>
                    <th>Referentiel</th>
                    <th>Date</th>
                    <th>Libelle</th>
                    <th>Duree</th>
                    <th>Etat</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="entity-main">@item.Etudiant?.NomComplet</span>
                        </td>
                        <td>@item.Etudiant?.Referentiel?.Libelle</td>
                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                        <td>@item.Libelle</td>
                        <td>@item.DureeHeures h</td>
                        <td>
                            <span class="pill @(item.Justifiee ? "pill--success" : "pill--warning")">
                                @(item.Justifiee ? "Justifiee" : "Non justifiee")
                            </span>
                        </td>
                        <td>
                            <div class="action-row">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Modifier</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
