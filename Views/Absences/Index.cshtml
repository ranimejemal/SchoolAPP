@model IEnumerable<Absence>
@{
    ViewData["Title"] = "Absences";
}

<section class="page-header page-header-inline">
    <div><h1>Absences</h1></div>
    <a asp-action="Create" class="btn btn-primary">Nouvelle absence</a>
</section>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Référentiel</th>
                    <th>Date</th>
                    <th>Libellé</th>
                    <th>Durée</th>
                    <th>État</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Etudiant?.NomComplet</td>
                        <td>@item.Etudiant?.Referentiel?.Libelle</td>
                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                        <td>@item.Libelle</td>
                        <td>@item.DureeHeures h</td>
                        <td>
                            <span class="badge @(item.Justifiee ? "text-bg-success" : "text-bg-warning")">
                                @(item.Justifiee ? "Justifiée" : "Non justifiée")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Modifier</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
