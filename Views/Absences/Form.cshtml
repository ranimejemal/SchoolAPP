@model Absence
@{
    var creation = Model.Id == 0;
    ViewData["Title"] = creation ? "Créer une absence" : "Modifier une absence";
}

<section class="page-header page-header-inline">
    <div><h1>@ViewData["Title"]</h1></div>
    <a asp-action="Index" class="btn btn-outline-dark">Retour</a>
</section>

<div class="panel-card form-card">
    <form asp-action="@(creation ? "Create" : "Edit")" method="post" class="row g-3">
        @if (!creation)
        {
            <input asp-for="Id" type="hidden" />
        }
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-md-4">
            <label asp-for="EtudiantId" class="form-label"></label>
            <select asp-for="EtudiantId" asp-items="ViewBag.Etudiants" class="form-select"></select>
            <span asp-validation-for="EtudiantId" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Date" class="form-label"></label>
            <input asp-for="Date" class="form-control" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="DureeHeures" class="form-label"></label>
            <input asp-for="DureeHeures" class="form-control" />
            <span asp-validation-for="DureeHeures" class="text-danger"></span>
        </div>
        <div class="col-md-8">
            <label asp-for="Libelle" class="form-label"></label>
            <input asp-for="Libelle" class="form-control" />
            <span asp-validation-for="Libelle" class="text-danger"></span>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="Justifiee" class="form-check-input" />
                <label asp-for="Justifiee" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
