@model IEnumerable<Etudiant>
@{
    ViewData["Title"] = "Etudiants";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Administration</span>
        <h1>Gestion des etudiants</h1>
        <p class="page-subtitle">Suivi des profils etudiants, referentiels et comptes lies.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nouvel etudiant</a>
</section>

<div class="panel-card">
    <div class="table-card__header">
        <div>
            <h2>Liste des etudiants</h2>
            <p class="muted-copy mb-0">@Model.Count() etudiant(s) enregistres.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Matricule</th>
                    <th>Etudiant</th>
                    <th>Referentiel</th>
                    <th>Absences</th>
                    <th>Compte</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="pill pill--neutral">@item.Matricule</span></td>
                        <td>
                            <span class="entity-main">@item.NomComplet</span>
                            <span class="entity-sub">@item.Email</span>
                        </td>
                        <td>@item.Referentiel?.Libelle</td>
                        <td>@item.Absences.Count</td>
                        <td>@(item.Compte?.Email ?? "Aucun")</td>
                        <td>
                            <div class="action-row">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Modifier</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
