@{
    ViewData["Title"] = "Accueil";
}

<div class="home-page">
    <section class="hero-panel home-hero mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <span class="eyebrow">Plateforme de gestion scolaire</span>
                <h1 class="display-5 mt-3">
                    Gérez les absences, les comptes et le suivi scolaire depuis une interface simple et professionnelle.
                </h1>
                <p class="hero-lead mt-3">
                    SchoolApp rassemble les modules essentiels de l'administration scolaire dans un seul espace :
                    authentification, gestion des étudiants, référentiels, tableau de bord et portail étudiant.
                </p>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg">Se connecter</a>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark btn-lg">Ouvrir le tableau de bord</a>
                </div>

                <div class="home-stat-strip mt-4">
                    <div class="home-stat">
                        <strong>Accès sécurisé</strong>
                        <span>Connexion par rôle pour administrateurs et utilisateurs</span>
                    </div>
                    <div class="home-stat">
                        <strong>Suivi des absences</strong>
                        <span>Consultation rapide avec filtres et synthèse claire</span>
                    </div>
                    <div class="home-stat">
                        <strong>Vision centralisée</strong>
                        <span>Un seul espace pour piloter les modules importants</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="panel-card home-highlight-card">
                    <span class="eyebrow">Vue d'ensemble</span>
                    <h2 class="mt-3">Un accueil plus clair pour démarrer rapidement.</h2>
                    <p class="muted-copy mt-3">
                        L'application est pensée pour aller à l'essentiel : accéder aux outils, consulter les informations
                        importantes et se connecter sans friction.
                    </p>

                    <div class="home-highlight-list mt-4">
                        <div class="home-highlight-item">
                            <span class="pill pill--neutral">01</span>
                            <div>
                                <strong>Tableau de bord administratif</strong>
                                <p>Suivez l'activité générale et les indicateurs utiles.</p>
                            </div>
                        </div>
                        <div class="home-highlight-item">
                            <span class="pill pill--neutral">02</span>
                            <div>
                                <strong>Gestion des utilisateurs et référentiels</strong>
                                <p>Organisez les données principales depuis une interface structurée.</p>
                            </div>
                        </div>
                        <div class="home-highlight-item">
                            <span class="pill pill--neutral">03</span>
                            <div>
                                <strong>Portail étudiant</strong>
                                <p>Permettez aux étudiants de consulter leurs absences plus simplement.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="row g-4 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="feature-card home-module-card">
                <div class="home-module-card__icon">A</div>
                <h3>Authentification</h3>
                <p>Connexion sécurisée avec séparation claire des accès selon les rôles.</p>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="feature-card home-module-card">
                <div class="home-module-card__icon">E</div>
                <h3>Étudiants</h3>
                <p>Gestion des fiches étudiantes et consultation des informations essentielles.</p>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="feature-card home-module-card">
                <div class="home-module-card__icon">S</div>
                <h3>Suivi des absences</h3>
                <p>Enregistrement et lecture rapide des absences avec affichage plus lisible.</p>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="feature-card home-module-card">
                <div class="home-module-card__icon">D</div>
                <h3>Dashboard</h3>
                <p>Indicateurs et synthèses pour aider à piloter l'établissement au quotidien.</p>
            </div>
        </div>
    </section>

    <section class="panel-card mb-4">
        <div class="row g-4">
            <div class="col-lg-7">
                <span class="eyebrow">Fonctionnement</span>
                <h2 class="mt-3">Une navigation pensée pour les besoins du quotidien.</h2>
                <p class="muted-copy mt-3">
                    SchoolApp met en avant les actions les plus utiles afin de réduire la complexité
                    et rendre l'utilisation plus agréable pour l'administration comme pour les étudiants.
                </p>

                <div class="home-flow mt-4">
                    <div class="home-step">
                        <div class="home-step__number">1</div>
                        <div>
                            <strong>Connexion</strong>
                            <p>Accédez à la plateforme avec un compte administrateur ou utilisateur.</p>
                        </div>
                    </div>
                    <div class="home-step">
                        <div class="home-step__number">2</div>
                        <div>
                            <strong>Gestion</strong>
                            <p>Consultez les modules, mettez à jour les données et suivez les opérations importantes.</p>
                        </div>
                    </div>
                    <div class="home-step">
                        <div class="home-step__number">3</div>
                        <div>
                            <strong>Suivi</strong>
                            <p>Analysez les statistiques et offrez une meilleure visibilité aux étudiants.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="info-card h-100">
                    <span class="eyebrow">Accès de démonstration</span>
                    <h3 class="mt-3">Comptes disponibles</h3>
                    <p class="muted-copy mt-2">
                        Utilisez ces comptes pour découvrir l'application et tester les différents parcours.
                    </p>

                    <div class="credential-list mt-4">
                        <div class="credential-card">
                            <span>Administrateur</span>
                            <strong>admin@schoolapp.local</strong>
                            <code>Admin123</code>
                        </div>
                        <div class="credential-card">
                            <span>Utilisateur</span>
                            <strong>sarra@schoolapp.local</strong>
                            <code>User123</code>
                        </div>
                        <div class="credential-card">
                            <span>Utilisateur</span>
                            <strong>omar@schoolapp.local</strong>
                            <code>User123</code>
                        </div>
                    </div>

                    <a asp-controller="Auth" asp-action="Login" class="btn btn-primary mt-4">Accéder à la connexion</a>
                </div>
            </div>
        </div>
    </section>

    <section class="info-card home-cta">
        <div class="row g-3 align-items-center">
            <div class="col-lg-8">
                <span class="eyebrow">SchoolApp</span>
                <h2 class="mt-3 mb-2">Une base claire pour une gestion scolaire plus fluide.</h2>
                <p class="muted-copy mb-0">
                    L'objectif est de proposer une interface sobre, lisible et utile, sans surcharge visuelle.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark">Voir le dashboard</a>
            </div>
        </div>
    </section>
</div>
