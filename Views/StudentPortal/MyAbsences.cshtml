@model StudentAbsencesViewModel
@{
    ViewData["Title"] = "Mes absences";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Espace etudiant</span>
        <h1>@Model.StudentName</h1>
        <p class="page-subtitle">@Model.Referentiel</p>
    </div>
    <span class="pill pill--neutral">@Model.Absences.Count absence(s)</span>
</section>

<div class="panel-card mb-4">
    <div class="form-card__header">
        <div>
            <h2>Recherche</h2>
            <p class="muted-copy mb-0">Filtrez vos absences par date ou par motif.</p>
        </div>
    </div>

    <form method="get" class="filter-grid">
        <div>
            <label class="form-label">Date</label>
            <input type="date" name="date" value="@(Model.Date?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div>
            <label class="form-label">Libelle</label>
            <input type="text" name="libelle" value="@Model.Libelle" class="form-control" placeholder="Maladie, retard, rendez-vous..." />
        </div>
        <div class="d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Rechercher</button>
        </div>
    </form>
</div>

<div class="panel-card">
    <div class="table-card__header">
        <div>
            <h2>Historique des absences</h2>
            <p class="muted-copy mb-0">Visualisez vos absences et leur etat de justification.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Libelle</th>
                    <th>Duree</th>
                    <th>Etat</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Absences.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center muted-copy py-4">Aucune absence trouvee.</td>
                    </tr>
                }
                else
                {
                    @foreach (var absence in Model.Absences)
                    {
                        <tr>
                            <td>@absence.Date.ToString("dd/MM/yyyy")</td>
                            <td>@absence.Libelle</td>
                            <td>@absence.DureeHeures h</td>
                            <td>
                                <span class="pill @(absence.Justifiee ? "pill--success" : "pill--danger")">
                                    @(absence.Justifiee ? "Justifiee" : "Non justifiee")
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
