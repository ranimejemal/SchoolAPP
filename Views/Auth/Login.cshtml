@model LoginViewModel
@{
    ViewData["Title"] = "Connexion";
}

<div class="auth-shell">
    <div class="auth-card">
        <span class="eyebrow">Acces securise</span>
        <h1 class="mt-3">Connexion a SchoolApp</h1>
        <p class="muted-copy">
            Connectez-vous avec un compte administrateur pour gerer l'ecole ou avec un compte utilisateur
            pour consulter les absences.
        </p>

        <form asp-action="Login" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="nom@schoolapp.local" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Votre mot de passe" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Se connecter</button>
        </form>

        <div class="auth-meta">
            <strong>Acces rapide</strong><br />
            Admin: <code>admin@schoolapp.local</code> / <code>Admin123</code><br />
            User: <code>sarra@schoolapp.local</code> / <code>User123</code>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
